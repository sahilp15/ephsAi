# =============================================================================
# Eddy — environment variables
# Copy this file to `.env.local` and fill in your keys. NEVER commit real keys.
# =============================================================================

# --- Required: Google Gemini (primary AI provider) -------------------------
# Get a FREE key (no credit card) at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# --- Optional: Groq (fallback AI provider) ---------------------------------
# Used automatically if Gemini is rate-limited (HTTP 429). Free key at
# https://console.groq.com/keys . If unset, Eddy shows a friendly "busy" note
# instead of falling back.
GROQ_API_KEY=

# Optional: override the Groq model. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: Vercel KV (feedback persistence) ----------------------------
# If these exist, thumbs/feedback are stored in Vercel KV. Otherwise feedback
# is logged to the server console (no-op stub). No personal data is ever stored.
# These are provided automatically when you add a KV store in the Vercel
# dashboard (Storage tab).
KV_REST_API_URL=
KV_REST_API_TOKEN=
