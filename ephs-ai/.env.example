# ==============================================================================
# EPHS AI — environment variables
# Copy this file to `.env.local` and fill in values. NEVER commit real keys.
# ==============================================================================

# --- AI provider (OpenAI) -----------------------------------------------------
# Server-only. The key is never exposed to the browser. If unset, the app stays
# fully functional and the recommender runs in deterministic "Smart match mode".
OPENAI_API_KEY=

# Optional: override the OpenAI model used for recommendations.
# Defaults to gpt-4o-mini (fast, low cost). Any chat-completions model works.
OPENAI_MODEL=gpt-4o-mini

# --- App ----------------------------------------------------------------------
# Public URL of the deployed app (used in exports/links).
APP_URL=http://localhost:3000

# Max AI recommendation requests per user/IP per hour.
AI_RATE_LIMIT_PER_HOUR=20

# Demo mode: "true" enables the seeded fictional demo students (no real
# student accounts required). Safe default for leadership presentations.
DEMO_MODE=true

# --- Supabase (production persistence path — optional for local demo) ---------
# The MVP runs without Supabase: catalog is served from the versioned dataset
# and student plans persist in the browser. To enable hosted Postgres + Auth
# + RLS, create a Supabase project, run the migrations in supabase/migrations,
# run `npm run data:import`, and fill these in. See docs/DATA_IMPORT_PLAN.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is used ONLY by trusted server-side import/admin scripts.
SUPABASE_SERVICE_ROLE_KEY=
