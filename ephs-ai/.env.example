# ==============================================================================
# EPHS AI - environment variables
# Copy this file to `.env.local` and fill in values. NEVER commit real keys.
# ==============================================================================

# --- AI provider (OpenAI) -----------------------------------------------------
# Server-only. The key is never exposed to the browser. If unset, the app stays
# fully functional and the assistant answers with deterministic catalog lookups.
OPENAI_API_KEY=

# Optional: override the OpenAI model used by the EPHS AI Assistant.
# Defaults to gpt-4o (accurate, strong instruction following). Any
# chat-completions model works.
OPENAI_MODEL=gpt-4o

# --- App ----------------------------------------------------------------------
# Public URL of the deployed app (used in exports/links).
APP_URL=http://localhost:3000

# Max assistant requests per user/IP per hour.
AI_RATE_LIMIT_PER_HOUR=20

# Demo mode: "true" enables the seeded fictional demo students (no real
# student accounts required). Safe default for leadership presentations.
DEMO_MODE=true

# --- Supabase (authentication, database, private storage) ---------------------
# Required to enable Google sign-in, accounts, onboarding, transcripts, saved
# plans, and the admin dashboard. Without these the public catalog + assistant
# still work, but the authenticated experience is disabled. Setup:
#   1. Create a Supabase project.
#   2. Run supabase/migrations/*.sql (0001 then 0002) in the SQL editor.
#   3. In Auth > Providers, enable Google and add your Google OAuth client
#      id/secret (from Google Cloud Console). Add
#      `${APP_URL}/auth/callback` as an authorized redirect URL there.
#   4. Run `npm run data:import` to load the catalog into Postgres (optional).
#   5. Fill in the three values below.
# NOTE: The OAuth *client secret* lives in Supabase Auth settings, never here
#       and never in client code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: trusted server-side only (transcript processing, audit,
# admin scripts). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Authorization rules (server-side; never shipped to the client) -----------
# Exact domain a student's verified Google email must end with.
STUDENT_EMAIL_DOMAIN=ep-student.org
# Exact domain that confers administrator access.
ADMIN_EMAIL_DOMAIN=edenpr.k12.mn.us
# Comma-separated allowlist of explicitly approved administrator emails, in
# addition to the admin domain. The temporary exception is included by default.
# Add more approved admins here (or via the in-app Admin > Access page).
ADMIN_EMAIL_ALLOWLIST=sahil.parasharami@gmail.com

# --- Transcript pipeline ------------------------------------------------------
# Private Supabase Storage bucket for uploaded transcript files (created by the
# 0002 migration). Files live under `{userId}/...` and are never public.
TRANSCRIPT_BUCKET=transcripts
# Extraction backend: "heuristic" (built-in, no external calls; reads text-based
# PDFs) or "openai" (vision extraction for images/scans; requires OPENAI_API_KEY).
TRANSCRIPT_EXTRACTION_PROVIDER=heuristic
# Max transcript upload size, in megabytes.
MAX_TRANSCRIPT_UPLOAD_MB=15
